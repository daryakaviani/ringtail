# Custom rounding function to the nearest multiple of p
def round_to_nearest_multiple(coeff, p):
    coeff_int = int(coeff)
    half_p = p // 2
    remainder = coeff_int % p
    if remainder >= half_p:
        return coeff_int + (p - remainder)
    else:
        return coeff_int - remainder

# Round H to the nearest multiple of p
H_after_rounding = Rq([round_to_nearest_multiple(coeff, p) for coeff in H_before_rounding.list()])
print("H -- after rounding to the nearest multiple of p")
print(H_after_rounding)


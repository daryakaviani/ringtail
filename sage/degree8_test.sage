# Vector z for party 0 (calculated manually)
z_party0_calculated = s * c + concatR + mask_prime
print("Calculated Vector z for party 0:")
print(z_party0_calculated)

# Compute z_sum (sum of z for all parties minus their respective masks)
z_sum = z_party0_calculated - mask
print("z_sum:")
print(z_sum)

# Compute Az
Az = A * z_sum
print("Az")
print(Az)

# Compute bc
bc = b * c
print("bc")
print(bc)

# Compute Az - bc
Az_bc = Az - bc
print("Az-bc before rounding")
print(Az_bc)

# Round Az_bc to the nearest multiple of p
Az_bc_rounded = Rq([round_to_nearest_multiple(coeff, p) for coeff in Az_bc.list()])
print("Az-bc after rounding")
print(Az_bc_rounded)

# Compute Delta = H_after_rounding - Az_bc_rounded
Delta_calculated = H_after_rounding - Az_bc_rounded
print("Calculated Vector Delta:")
print(Delta_calculated)

# Verify Delta Norm and Beta Delta
delta_coeffs = Delta_calculated.list()
delta_norm = max([min(int(coeff), q - int(coeff)) for coeff in delta_coeffs])
beta_delta = ((B * p) - q) / (2 * q)
beta_delta = int(beta_delta)

print("Delta Norm:", delta_norm)
print("Beta Delta:", beta_delta)

if delta_norm <= beta_delta:
    print("Delta norm is within the acceptable range.")
else:
    print("Delta norm exceeds the acceptable range.")

# Confirming consistency with given values
def compare_vectors(vector1, vector2, name):
    if vector1 == vector2:
        print(f"{name} matches the given value.")
    else:
        print(f"{name} does NOT match the given value.")

